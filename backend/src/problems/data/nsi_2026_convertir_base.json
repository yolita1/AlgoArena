{
  "id": "nsi_2026_convertir_base",
  "title": "Conversion en binaire",
  "description": "Convertir un entier positif en binaire, sans utiliser `bin()`.\n\nAlgorithme : diviser successivement par 2 et lire les restes à rebours.",
  "inputSpec": "Un entier n ≥ 1.",
  "outputSpec": "La représentation binaire de n.",
  "constraints": "1 ≤ n ≤ 2^30",
